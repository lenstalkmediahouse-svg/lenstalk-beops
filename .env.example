NODE_ENV=production
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000

# Database Access
DATABASE_URL=postgresql://user:password@localhost:5432/lenstalk_os
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/lenstalk_os?retryWrites=true&w=majority

# SECURITY
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=8h
COOKIE_NAME=lenstalk_session
COOKIE_SECURE=false

# MAILER CONFIG
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=your_smtp_password
MAIL_FROM="Lenstalk OS <no-reply@example.com>"

# DEMO SEED PASSWORDS
DEMO_ADMIN_PASSWORD=LenstalkAdmin@2026
DEMO_HR_PASSWORD=LenstalkHr@2026
DEMO_OPERATIONS_PASSWORD=LenstalkOps@2026
DEMO_ADS_MANAGER_PASSWORD=LenstalkAds@2026
DEMO_EMPLOYEE_PASSWORD=LenstalkEmployee@2026
DEMO_SALES_PASSWORD=LenstalkSales@2026
DEMO_CINEMATOGRAPHER_PASSWORD=LenstalkCinema@2026
DEMO_CLIENT_PASSWORD=LenstalkClient@2026
